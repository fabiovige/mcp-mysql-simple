{
    "name": "mcp-mysql-server-simple",
    "version": "1.1.0",
    "description": "Servidor MCP otimizado para MySQL - Arquitetura limpa com SOLID",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "tsx src/index.ts",
        "test": "vitest --run",
        "test:connection": "node test-mysql-connection.js",
        "test:server": "npm run build && node test-server.js",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.4",
        "dotenv": "^16.5.0",
        "mysql2": "^3.11.4"
    },
    "devDependencies": {
        "@types/node": "^22.10.2",
        "fast-check": "^4.8.0",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2",
        "vitest": "^4.1.7"
    },
    "engines": {
        "node": ">=18"
    },
    "keywords": [
        "mcp",
        "mysql",
        "server",
        "typescript",
        "optimized",
        "clean-architecture",
        "solid"
    ],
    "author": "Fabio",
    "license": "MIT"
}
